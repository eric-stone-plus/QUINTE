{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/eric-stone-plus/QUINTE/schemas/lane-output.schema.json",
  "title": "QUINTE Lane Output",
  "type": "object",
  "additionalProperties": false,
  "required": ["lane_output_version", "task_restatement", "verdict", "confidence", "claims", "residuals", "uncertainties"],
  "properties": {
    "lane_output_version": { "const": "1.0" },
    "task_restatement": { "type": "string", "minLength": 1, "maxLength": 4000 },
    "verdict": { "type": "string", "minLength": 1, "maxLength": 20000 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "claims": {
      "type": "array",
      "maxItems": 100,
      "items": { "$ref": "#/$defs/claim" }
    },
    "residuals": {
      "type": "array",
      "maxItems": 100,
      "items": { "$ref": "#/$defs/residual" }
    },
    "uncertainties": {
      "type": "array",
      "maxItems": 100,
      "items": { "type": "string", "minLength": 1, "maxLength": 4000 }
    }
  },
  "$defs": {
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "statement", "evidence_refs", "confidence", "category"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z0-9._-]{1,64}$" },
        "statement": { "type": "string", "minLength": 1, "maxLength": 8000 },
        "evidence_refs": { "type": "array", "maxItems": 30, "items": { "type": "string", "maxLength": 1000 } },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "category": { "type": "string", "minLength": 1, "maxLength": 100 }
      }
    },
    "residual": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "severity", "residual_type", "source", "finding", "evidence_refs", "disposition", "required_closure", "closure_state", "closure_evidence", "scope"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z0-9._-]{1,64}$" },
        "severity": { "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL", "P0"] },
        "residual_type": { "type": "string", "minLength": 1, "maxLength": 100 },
        "source": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "finding": { "type": "string", "minLength": 1, "maxLength": 8000 },
        "evidence_refs": { "type": "array", "maxItems": 30, "items": { "type": "string", "maxLength": 1000 } },
        "disposition": { "enum": ["verified", "falsified", "unresolved", "escalated", "discarded"] },
        "required_closure": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "closure_state": { "enum": ["open", "closed", "blocked", "waived", "not_applicable"] },
        "closure_evidence": { "type": "array", "maxItems": 30, "items": { "type": "string", "maxLength": 1000 } },
        "scope": { "type": "string", "minLength": 1, "maxLength": 2000 }
      }
    }
  }
}
