{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/eric-stone-plus/QUINTE/schemas/dispatch-manifest.schema.json",
  "title": "QUINTE Dispatch Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "dispatch_manifest_version",
    "run_id",
    "phase",
    "question",
    "prompt_ref",
    "archive_dir",
    "timeout_seconds",
    "max_attempts",
    "retry_backoff_seconds",
    "prompt_shrink_char_limit",
    "substitution_policy",
    "parties",
    "auditor_b",
    "non_authorization"
  ],
  "properties": {
    "dispatch_manifest_version": {
      "type": "string",
      "const": "1.0"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "phase": {
      "type": "string",
      "enum": ["R1", "R2", "R3"]
    },
    "question": {
      "type": "string",
      "minLength": 1
    },
    "prompt_ref": {
      "type": "string",
      "minLength": 1
    },
    "archive_dir": {
      "type": "string",
      "minLength": 1
    },
    "timeout_seconds": {
      "type": "integer",
      "minimum": 1
    },
    "max_attempts": {
      "type": "integer",
      "minimum": 1
    },
    "retry_backoff_seconds": {
      "type": "number",
      "minimum": 0
    },
    "prompt_shrink_char_limit": {
      "type": "integer",
      "minimum": 1
    },
    "substitution_policy": {
      "type": "string",
      "const": "same_route_only"
    },
    "parties": {
      "type": "array",
      "minItems": 0,
      "maxItems": 5,
      "items": {
        "$ref": "#/$defs/route"
      }
    },
    "auditor_b": {
      "anyOf": [
        {
          "$ref": "#/$defs/route"
        },
        {
          "type": "null"
        }
      ]
    },
    "non_authorization": {
      "type": "string",
      "const": "QUINTE dispatch manifests do not authorize action, substitute parties, or modify routing rules."
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "phase": {
            "enum": ["R1", "R2"]
          }
        }
      },
      "then": {
        "properties": {
          "parties": {
            "minItems": 5,
            "maxItems": 5
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "phase": {
            "const": "R3"
          }
        }
      },
      "then": {
        "properties": {
          "parties": {
            "anyOf": [
              {
                "maxItems": 0
              },
              {
                "minItems": 5,
                "maxItems": 5
              }
            ]
          },
          "auditor_b": {
            "$ref": "#/$defs/route"
          }
        }
      }
    }
  ],
  "$defs": {
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "route_id", "command", "required"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "route_id": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": {
          "type": "boolean",
          "const": true
        }
      }
    }
  }
}
